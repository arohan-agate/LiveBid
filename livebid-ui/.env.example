# Google OAuth client ID (same one the backend verifies against)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Backend base URL. Omit for local dev (defaults to http://localhost:8080).
# In production (e.g. Vercel) set this to your deployed backend, e.g.:
# NEXT_PUBLIC_API_URL=https://livebid-api.onrender.com
NEXT_PUBLIC_API_URL=
